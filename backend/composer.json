{
    "name": "teacher-app/backend",
    "description": "Teacher Management API - CodeIgniter 4",
    "type": "project",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.5",
        "firebase/php-jwt": "^6.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter\\ComposerScripts::postUpdate"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
